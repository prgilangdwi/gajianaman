# Supabase — get these from supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenRouter — server-side only, used by /api/* serverless functions
# Set in Vercel Dashboard → Environment Variables for production
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
APP_URL=https://gajianaman.xyz

# Google OAuth redirect (optional — defaults to origin + /auth/v1/callback)
VITE_AUTH_REDIRECT_URL=https://gajianaman.xyz/auth/v1/callback
