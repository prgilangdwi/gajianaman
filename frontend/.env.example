# Supabase — get these from supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — server-side only, used by /api/parse-image serverless function
# Set in Vercel Dashboard → Environment Variables for production
# For local vercel dev, add it here (NOT prefixed with VITE_ so it stays server-side)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
